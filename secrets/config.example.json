    "download_dir_preprocessed": "cache/preprocessed"
  },
  "cache": {
    "directory": "cache",
    "max_image_size_mb": 10
  },
  "tracking": {
    "file": "tracking.json"
  },
  "preprocessing": {
    "processor_id": "username"
  }
}
