{
  "google_custom_search": {
    "api_key": "YOUR_GOOGLE_CUSTOM_SEARCH_API_KEY",
    "search_engine_id": "YOUR_SEARCH_ENGINE_ID",
    "num_results": 10
  },
  "google_drive": {
    "credentials_path": "path/to/your/service-account-credentials.json",
    "raw_folder_id": "YOUR_DRIVE_FOLDER_ID",
    "preprocessed_folder_id": "YOUR_DRIVE_FOLDER_ID",
